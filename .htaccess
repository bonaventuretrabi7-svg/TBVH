# ================================================================
# KBINE PLUS | URLs propres (sans extension .html)
# ================================================================
# Utile maintenant que le site tourne sur son propre nom de domaine
# (hébergement Hostinger, Apache/LiteSpeed avec mod_rewrite) : les
# fichiers admin.html/cabine.html restent en place tels quels — les
# supprimer casserait le site (et l'app Android, qui n'a aucun serveur
# pour réécrire les URLs) — seule l'adresse affichée dans le navigateur
# change, jamais le contenu réellement servi.

DirectoryIndex index.html

<IfModule mod_rewrite.c>
  RewriteEngine On

  # /admin.html ou /cabine.html tapé/partagé directement → redirige vers
  # l'adresse propre sans extension (jamais index.html, déjà la racine).
  RewriteCond %{THE_REQUEST} \s/+(admin|cabine)\.html[\s?] [NC]
  RewriteRule ^(admin|cabine)\.html$ /$1 [R=301,L]

  # Sert le vrai fichier .html quand l'URL sans extension est demandée —
  # uniquement si aucun fichier/dossier réel ne porte déjà ce nom exact.
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME}\.html -f
  RewriteRule ^([^/]+)$ $1.html [L]
</IfModule>

<IfModule mod_headers.c>
  # L'app Android (contenu local, autre origine) doit pouvoir lire ce
  # fichier en cross-origin pour détecter les mises à jour — voir
  # js/update-notifier.js. Étendue à app-version.json uniquement,
  # aucune donnée sensible.
  <Files "app-version.json">
    Header set Access-Control-Allow-Origin "*"
  </Files>

  # Mise à jour automatique côté web : un client web doit toujours recevoir
  # le HTML/JS/CSS fraîchement déployés au chargement suivant, jamais une
  # version mise en cache par le navigateur avant le dernier déploiement
  # (contrairement à l'app Android, figée dans l'APK — voir
  # js/update-notifier.js). "no-cache" ne désactive pas le cache : il force
  # simplement une revalidation (requête conditionnelle) à chaque
  # chargement, donc un fichier inchangé reste servi instantanément
  # (304 Not Modified), et un fichier modifié est immédiatement récupéré —
  # sans dépendre d'un paramètre ?v= à incrémenter manuellement sur chaque
  # <script>/<link> (source d'oublis, voir js/admin.js qui n'en avait
  # aucun avant ce correctif).
  <FilesMatch "\.(html|js|css)$">
    Header set Cache-Control "no-cache"
  </FilesMatch>
</IfModule>
